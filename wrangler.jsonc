{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "iceberg-themes",
	"compatibility_date": "2025-05-13",
	"workers_dev": false,
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
	},
	"routes": [
		{ "pattern": "themes.icebergmedia.co.uk/*", "zone_name": "icebergmedia.co.uk" }
	],
	"r2_buckets": [
		{
			"bucket_name": "site-assets",
			"binding": "site_assets",
		}
	],
}
