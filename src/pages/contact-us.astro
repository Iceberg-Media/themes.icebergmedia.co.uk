---
import MainLayout from '~/layouts/MainLayout.astro';
import ContactForm from './themes/_components/ContactForm.astro';
---

<MainLayout
	title="Contact Us | IcebergMedia.co.uk"
	description="Get in touch with Iceberg Media. Theme setup, custom design, SEO, and web development services. Based in Manchester, UK."
>
	<div class="relative bg-grid">
		<div class="grid-container py-16 sm:py-20 md:py-24 xl:py-32">
			<div class="relative flex flex-col items-center gap-6 text-center max-w-3xl mx-auto">
				<h1 class="heading-3 sm:heading-2 md:heading-1">Contact Us</h1>
				<p class="text-astro-gray-200 text-lg">Ready to launch your website? Get in touch and we'll get back to you within 24 hours.</p>
			</div>
		</div>
	</div>

	<div class="grid-container py-16 md:py-24">
		<div class="max-w-4xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				<!-- NAP+W Details -->
				<div class="space-y-8">
					<div>
						<h2 class="heading-3 mb-6">Get In Touch</h2>
						<div class="space-y-6">
							<div class="flex items-start gap-4">
								<div class="w-10 h-10 rounded-lg bg-blue-purple-gradient flex items-center justify-center shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
								</div>
								<div>
									<h3 class="font-semibold text-white mb-1">Address</h3>
									<p class="text-astro-gray-200">14 Commercial Street<br/>Manchester, M15 4PZ<br/>United Kingdom</p>
								</div>
							</div>

							<div class="flex items-start gap-4">
								<div class="w-10 h-10 rounded-lg bg-blue-purple-gradient flex items-center justify-center shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
								</div>
								<div>
									<h3 class="font-semibold text-white mb-1">Phone</h3>
									<p class="text-astro-gray-200"><a href="tel:+447367274351" class="hover:text-white transition-colors">07367 274 351</a></p>
								</div>
							</div>

							<div class="flex items-start gap-4">
								<div class="w-10 h-10 rounded-lg bg-blue-purple-gradient flex items-center justify-center shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
								</div>
								<div>
									<h3 class="font-semibold text-white mb-1">Email</h3>
									<p class="text-astro-gray-200"><a href="mailto:support@IcebergMedia.co.uk" class="hover:text-white transition-colors">support@IcebergMedia.co.uk</a></p>
								</div>
							</div>

							<div class="flex items-start gap-4">
								<div class="w-10 h-10 rounded-lg bg-blue-purple-gradient flex items-center justify-center shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
								</div>
								<div>
									<h3 class="font-semibold text-white mb-1">Website</h3>
									<p class="text-astro-gray-200"><a href="https://IcebergMedia.co.uk" class="hover:text-white transition-colors">IcebergMedia.co.uk</a></p>
								</div>
							</div>
						</div>
					</div>

					<div>
						<h3 class="font-semibold text-white mb-3">Business Hours</h3>
						<div class="text-astro-gray-200 space-y-1 text-sm">
							<p>Monday - Friday: 9:00 AM - 6:00 PM</p>
							<p>Saturday: 10:00 AM - 2:00 PM</p>
							<p>Sunday: Closed</p>
						</div>
					</div>
				</div>

				<!-- Map -->
				<div class="rounded-xl overflow-hidden border border-astro-gray-500 h-[400px] md:h-auto">
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2375.5!2d-2.25!3d53.46!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDI3JzM2LjAiTiAywrAxNScwMC4wIlc!5e0!3m2!1sen!2suk!4v1"
						width="100%"
						height="100%"
						style="border:0; min-height: 400px;"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						title="Iceberg Media office location"
					></iframe>
				</div>
			</div>
		</div>
	</div>

	<ContactForm />

	<!-- Structured Data for Local Business -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "LocalBusiness",
		"name": "Iceberg Media",
		"image": "https://themes.icebergmedia.co.uk/iceberg-textlogo.png",
		"url": "https://IcebergMedia.co.uk",
		"telephone": "+447367274351",
		"email": "support@IcebergMedia.co.uk",
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "14 Commercial Street",
			"addressLocality": "Manchester",
			"postalCode": "M15 4PZ",
			"addressCountry": "GB"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 53.46,
			"longitude": -2.25
		},
		"openingHoursSpecification": [
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
				"opens": "09:00",
				"closes": "18:00"
			},
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": "Saturday",
				"opens": "10:00",
				"closes": "14:00"
			}
		],
		"sameAs": [
			"https://x.com/iceberg_media",
			"https://www.linkedin.com/company/iceberg-media/",
			"https://www.youtube.com/user/IcebergMediaUK"
		]
	})} />
</MainLayout>
