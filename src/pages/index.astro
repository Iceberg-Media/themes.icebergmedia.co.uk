---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { THEMES_API_URL } from '~/helpers/constants.ts';
import MainLayout from '~/layouts/MainLayout.astro';
import Blog from './themes/_assets/blog.webp';
import Docs from './themes/_assets/docs.webp';
import Ecommerce from './themes/_assets/ecommerce.webp';
import LandingPage from './themes/_assets/landing-page.webp';
import More from './themes/_assets/more-themes.webp';
import Portfolio from './themes/_assets/portfolio.webp';
import ThemeCard from './themes/_components/ThemeCard.astro';
import ContactForm from './themes/_components/ContactForm.astro';
import type { ThemeAndAuthor } from './themes/_types/index.ts';

export const prerender = false;

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=60, stale-while-revalidate=86400');

// Fetch all themes and pick the best-looking ones for the homepage
const allThemes: ThemeAndAuthor[] = await fetch(
	`${THEMES_API_URL}/api/themes`,
).then((res) => res.json());

// Curated list of good-looking business themes
const featuredSlugs = [
	'monarque',
	'tally-saas-product-astro-theme',
	'axis-studio',
	'constellation',
	'blast-blue-astro-theme',
	'astro-keel',
];

const popularThemes = featuredSlugs
	.map((slug) => allThemes.find((t) => t.Theme.slug === slug))
	.filter(Boolean) as ThemeAndAuthor[];

const pageData = {
	seo: {
		title: 'Free & Premium Website Themes | Professional Theme Setup UK',
		description: 'Browse 200+ free and premium website themes for blogs, portfolios, e-commerce, and landing pages. Professional theme setup from £299. Manchester-based, serving all of the UK.',
		image: { src: '/og/themes.jpg', alt: 'Free and Premium Website Themes - Professional Theme Setup UK' },
	},
	header: {
		title: 'Find Your Perfect Website Theme',
		tagline: 'Browse 200+ free and premium themes. Pick one you love and we\'ll set it up, customise it with your branding, and launch it for you.',
	},
	categories: {
		title: 'Find the theme for you',
		tagline: 'Launch your next site at light speed with our catalog of free and premium website themes',
		cards: [
			{
				href: '/themes/1/?search=&categories%5B%5D=blog',
				title: 'Blogs',
				description: 'Whether you want sleek minimalism or bold colors, find the blog template for you.',
				cta: 'Browse blog themes',
				image: Blog,
			},
			{
				href: '/themes/1/?search=&categories%5B%5D=ecommerce',
				title: 'E-commerce',
				description: 'Every second counts. Find an e-commerce template that loads fast and looks great.',
				cta: 'Browse e-commerce themes',
				image: Ecommerce,
			},
			{
				href: '/themes/1/?search=&categories%5B%5D=landing-page',
				title: 'Landing pages',
				description: 'Showcase your product or service with a stylish landing page template.',
				cta: 'Browse landing page themes',
				image: LandingPage,
			},
			{
				href: '/themes/1/?search=&categories%5B%5D=portfolio',
				title: 'Portfolio',
				description: 'Share your art, coding projects, music, and more with a portfolio theme.',
				cta: 'Browse portfolio themes',
				image: Portfolio,
			},
			{
				href: '/themes/1/?search=&categories%5B%5D=docs',
				title: 'Documentation',
				description: 'Ship your next technical documentation website with a docs theme.',
				cta: 'Browse docs themes',
				image: Docs,
			},
			{
				href: '/themes/1/',
				title: '...and more!',
				description: 'Discover all website themes and filter by your favorite technology, from Tailwind to Vue.',
				cta: 'Browse all themes',
				image: More,
				persist: true,
			},
		],
	},
};
---

<MainLayout {...pageData.seo}>
	<div class="relative pb-16 overflow-hidden">
		<div class="relative grid-container py-10 sm:py-12 md:py-16">
			<div class="absolute inset-0 bg-grid mask-linear-gradient-to-b bleed-full"></div>
			<div class="relative flex flex-col items-center gap-6 text-center">
				<h1
					class="mx-auto max-w-screen-lg heading-3 sm:heading-2 md:heading-1"
					set:text={pageData.header.title}
				/>
				<p class="text-astro-gray-200 text-lg max-w-2xl mx-auto" set:text={pageData.header.tagline} />
				<a href="/themes/1/" class="button button-primary">Browse All Themes</a>
			</div>
		</div>

		<div class="grid-container pt-6 pb-12 border-astro-gray-500 border-t overflow-hidden">
			<section>
				<div>
					<h2
						class="heading-4 sm:heading-3 md:heading-2"
						id="featured"
					>Popular themes</h2>
					<p class="text-astro-gray-200 body md:body-large">Newest free themes, hand-picked and ready for your next project</p>
				</div>
				<div class="gap-6 md:gap-10 grid md:grid-cols-2 lg:grid-cols-3 mt-6">
					{popularThemes.map((theme) => <ThemeCard {theme} />)}
				</div>
				<div class="flex justify-center mt-[4.5rem]">
					<a href="/themes/1/" class="button button-primary">Browse all themes</a>
				</div>
			</section>
		</div>

		<div class="grid-container py-12 border-astro-gray-500 border-t overflow-hidden">
			<section class="space-y-14">
				<div class="flex flex-col items-start">
					<h2
						class="bg-blue-purple-gradient bg-clip-text font-semibold text-transparent"
						set:text={pageData.categories.title}
					/>
					<p
						class="mt-1 text-white text-balance heading-4 sm:heading-3 md:heading-2"
						id="categories"
						set:text={pageData.categories.tagline}
					/>
				</div>

				<div class="gap-6 md:gap-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 mt-4 sm:mt-8">
					{
						pageData.categories.cards.map(({ href, title, description, cta, image, persist }) => (
							<div
								class:list={[
									'relative group flex flex-col p-1 border border-astro-dark-100/20  rounded-xl xl:rounded-2xl overflow-hidden',
									'transition-colors duration-500',
									'hover:border-astro-dark-100/40',
									'focus-within:outline outline-2 outline-offset-2 outline-astro-pink-light',
								]}
							>
								<div class="md:space-y-2 p-3">
									<h3 class="font-semibold text-white text-lg">
										<a
											{href}
											class="after:absolute after:z-10 after:inset-0 group-focus-within:outline-none"
											set:text={title}
										/>
									</h3>
									<p
										class="font-light text-astro-gray-200 text-sm xl:text-base md:text-balance"
										set:text={description}
									/>
								</div>
								<div class="relative">
									<div class="rounded-lg xl:rounded-xl overflow-clip relative">
										<Image src={image} alt="" class:list={[`w-full object-cover`]} />
										<div
											class:list={[
												'opacity-0 absolute inset-0 bg-astro-gray-700/80',
												'transition-opacity duration-500',
												'group-hover:opacity-100 group-focus-within:opacity-100',
											]}
										/>
									</div>
									<div
										class:list={[
											'absolute inset-0 flex justify-center items-center',
											'transition-opacity duration-500',
											!persist &&
												'opacity-0 group-hover:opacity-100 group-focus-within:opacity-100',
										]}
									>
										<p
											class:list={[
												'flex items-center px-4 py-2 bg-astro-gray-600/50 text-astro-gray-200 border border-astro-gray-400/30 rounded-full',
												'transition-colors duration-500',
												'group-hover:text-astro-gray-100 group-focus-within:text-astro-gray-100 group-hover:border-astro-gray-300/30 group-focus-within:border-astro-gray-300/30',
											]}
										>
											<span class="px-1 font-medium transition-colors">{cta}</span>
											<Icon name="right-arrow" class="w-6 h-6 transition-colors" />
										</p>
									</div>
								</div>
							</div>
						))
					}
				</div>
			</section>
		</div>
	</div>

	<ContactForm />
</MainLayout>
