---
import CardGrid from '~/components/CardGrid.astro';
import CardGridGroup from '~/components/CardGridGroup.astro';
import { THEMES_API_URL } from '~/helpers/constants.ts';
import MainLayout from '~/layouts/MainLayout.astro';
import ThemeCard from '../_components/ThemeCard.astro';
import ContactForm from '../_components/ContactForm.astro';
import type { ThemeAndAuthor } from '../_types/index.ts';

export const prerender = false;

const allThemes: ThemeAndAuthor[] = await fetch(
	`${THEMES_API_URL}/api/themes?categories[]=blog`,
).then((res) => res.json());

const themes = [...allThemes]
	.sort((a, b) => new Date(b.Theme.updatedAt).getTime() - new Date(a.Theme.updatedAt).getTime());
---

<MainLayout title="Blog Themes | Website Templates for Bloggers" description="Discover website themes designed for blogs and content creators. Clean typography, fast loading, and SEO-friendly blog templates. Free and premium options available.">
	<div class="relative bg-grid">
		<div class="grid-container">
			<h1 class="mx-auto pt-24 md:pt-32 lg:pt-40 w-full max-w-screen-xl text-center text-balance heading-3 sm:heading-2 lg:heading-1">
				Blog Themes
			</h1>
			<p class="text-center text-astro-gray-200 text-lg max-w-2xl mx-auto -mt-4">
				Website themes designed for bloggers and content creators. Clean typography, fast loading, and SEO-friendly.
			</p>
		</div>
	</div>

	<div class="grid-container py-12 md:py-16">
		<p class="text-astro-gray-200 text-sm mb-6">{themes.length} blog themes available</p>
		<CardGrid class="sm:grid-cols-2 xl:grid-cols-3">
			{themes.map((theme) => <ThemeCard theme={theme} />)}
		</CardGrid>
	</div>

	<ContactForm />
</MainLayout>
