---
import CatalogSubmitCallout, {
	type Props as CalloutProps,
} from '~/components/CatalogSubmitCallout.astro';

export type Props = Omit<CalloutProps, 'slot' | 'title' | 'cta'>;

const { ...attrs } = Astro.props;
---

<CatalogSubmitCallout
	title="Need a theme set up?"
	cta={{ href: '#contact-form', text: 'Get a quote' }}
	{...attrs}
>
	Pick a theme you love and we'll customise it with your branding, set up hosting, and launch your site. <a class="link link-underline" href="https://icebergmedia.co.uk">Learn more</a>.
</CatalogSubmitCallout>
