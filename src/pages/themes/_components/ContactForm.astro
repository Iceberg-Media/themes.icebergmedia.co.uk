---
// Iceberg Media Contact Form - for theme setup inquiries
---

<section id="contact-form" class="relative w-full py-10 md:py-14 bg-astro-gray-700">
	<div class="absolute inset-0 bg-grid opacity-30" style="mask-image: linear-gradient(to bottom, transparent, 10%, white, 90%, transparent);"></div>
	<div class="relative max-w-2xl mx-auto px-4 sm:px-8">
		<div class="text-center mb-6">
			<h2 class="heading-2 mb-2">Love a Theme? Let's Build It For You.</h2>
			<p class="text-astro-gray-200">Tell us which theme you want and we'll set it up, customise it with your branding, and launch it. Fast turnaround, professional results.</p>
		</div>

		<form
			id="theme-contact-form"
			action="https://themes-contact-form.iceberg.workers.dev"
			method="POST"
			class="flex flex-col gap-5 bg-astro-gray-600 border border-astro-gray-500 rounded-2xl p-6 md:p-10 shadow-xl"
		>
			<!-- Honeypot for spam prevention -->
			<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
				<div>
					<label for="contact-name" class="block text-sm text-astro-gray-200 mb-1.5">Your Name *</label>
					<input
						type="text"
						id="contact-name"
						name="name"
						required
						placeholder="John Smith"
						class="input w-full"
					/>
				</div>
				<div>
					<label for="contact-email" class="block text-sm text-astro-gray-200 mb-1.5">Email Address *</label>
					<input
						type="email"
						id="contact-email"
						name="email"
						required
						placeholder="john@example.com"
						class="input w-full"
					/>
				</div>
			</div>

			<div>
				<label for="contact-theme-name" class="block text-sm text-astro-gray-200 mb-1.5">Which Theme Do You Want? *</label>
				<input
					type="text"
					id="contact-theme-name"
					name="theme"
					required
					placeholder="e.g. Astro Keel, Pulsar, etc."
					class="input w-full"
				/>
			</div>

			<div>
				<label for="contact-business" class="block text-sm text-astro-gray-200 mb-1.5">Business / Project Name</label>
				<input
					type="text"
					id="contact-business"
					name="business"
					placeholder="Your business name"
					class="input w-full"
				/>
			</div>

			<div>
				<label for="contact-budget" class="block text-sm text-astro-gray-200 mb-1.5">Budget Range</label>
				<select
					id="contact-budget"
					name="budget"
					class="input w-full"
				>
					<option value="">Select budget range</option>
					<option value="under-500">Under &pound;500</option>
					<option value="500-1000">&pound;500 - &pound;1,000</option>
					<option value="1000-2500">&pound;1,000 - &pound;2,500</option>
					<option value="2500-5000">&pound;2,500 - &pound;5,000</option>
					<option value="5000-plus">&pound;5,000+</option>
				</select>
			</div>

			<div>
				<label for="contact-message" class="block text-sm text-astro-gray-200 mb-1.5">Tell Us About Your Project</label>
				<textarea
					id="contact-message"
					name="message"
					rows="4"
					placeholder="What pages do you need? Any specific features or customisations?"
					class="input input-textarea w-full"
				></textarea>
			</div>

			<button type="submit" class="button button-primary w-full">
				Send Inquiry
			</button>

			<p class="text-xs text-astro-gray-300 text-center">We'll respond within 24 hours. No spam, ever.</p>
		</form>
		<div id="form-success" class="hidden text-center py-10">
			<div class="text-4xl mb-4">&#10003;</div>
			<h3 class="heading-3 mb-2 text-white">Thank You!</h3>
			<p class="text-astro-gray-200">We've received your inquiry and will get back to you within 24 hours.</p>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById('theme-contact-form') as HTMLFormElement;
	const successMsg = document.getElementById('form-success');
	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
			btn.textContent = 'Sending...';
			btn.disabled = true;
			try {
				const resp = await fetch(form.action, {
					method: 'POST',
					body: new FormData(form),
				});
				if (resp.ok) {
					form.classList.add('hidden');
					successMsg?.classList.remove('hidden');
				} else {
					btn.textContent = 'Send Inquiry';
					btn.disabled = false;
					alert('Something went wrong. Please try again or email us directly at martin@icebergmedia.co.uk');
				}
			} catch {
				btn.textContent = 'Send Inquiry';
				btn.disabled = false;
				alert('Something went wrong. Please try again or email us directly at martin@icebergmedia.co.uk');
			}
		});
	}
</script>
