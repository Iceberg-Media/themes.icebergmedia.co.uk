---
import MainLayout from '~/layouts/MainLayout.astro';
import ContactForm from '../themes/_components/ContactForm.astro';
---

<MainLayout
	title="Free Website Themes | Download Professional Templates at No Cost"
	description="Browse our collection of free website themes for blogs, portfolios, e-commerce, landing pages, and more. Professional-quality templates you can download and use at no cost. Setup service available."
>
	<div class="relative bg-grid">
		<div class="grid-container py-10 sm:py-12 md:py-16">
			<div class="relative flex flex-col items-center gap-6 text-center max-w-3xl mx-auto">
				<h1 class="heading-3 sm:heading-2 md:heading-1">Free Website Themes</h1>
				<p class="text-astro-gray-200 text-lg">Professional-quality website templates you can download and use at no cost. Pick one and we'll set it up, customise it with your branding, and launch it for you.</p>
			</div>
		</div>
	</div>

	<div class="grid-container py-16 md:py-24">
		<div class="max-w-4xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<a href="/themes/free/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">Free Themes</h2>
					<p class="text-astro-gray-200 text-sm">No-cost website templates for any project.</p>
				</a>
				<a href="/themes/premium/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">Premium Themes</h2>
					<p class="text-astro-gray-200 text-sm">Professional paid themes for businesses.</p>
				</a>
				<a href="/blog/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">Blog Themes</h2>
					<p class="text-astro-gray-200 text-sm">Clean, fast templates for bloggers.</p>
				</a>
				<a href="/ecommerce/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">E-commerce</h2>
					<p class="text-astro-gray-200 text-sm">Online store templates ready to sell.</p>
				</a>
				<a href="/landing-page/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">Landing Pages</h2>
					<p class="text-astro-gray-200 text-sm">High-converting marketing pages.</p>
				</a>
				<a href="/portfolio/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">Portfolio</h2>
					<p class="text-astro-gray-200 text-sm">Showcase your work beautifully.</p>
				</a>
				<a href="/docs/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">Documentation</h2>
					<p class="text-astro-gray-200 text-sm">Technical writing and docs templates.</p>
				</a>
				<a href="/themes/" class="group bg-astro-gray-600 border border-astro-gray-500 rounded-xl p-8 hover:border-astro-blue transition-colors">
					<h2 class="heading-4 mb-3 group-hover:text-astro-blue transition-colors">All Themes</h2>
					<p class="text-astro-gray-200 text-sm">Browse our complete collection.</p>
				</a>
			</div>
		</div>
	</div>

	<ContactForm />
</MainLayout>
