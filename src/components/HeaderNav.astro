---
import siteInfo from '~/data/site-info.js';
import HeaderDropDown from './HeaderDropDown.astro';
import SocialLinks from './SocialLinks.astro';

const socialLinks = siteInfo.socialLinks.filter((link) => link.showInHeader);
---

<nav class="w-full flex items-center justify-between">
	<a href="/" data-astro-prefetch title="IcebergMedia.co.uk" data-home-link class="flex items-center gap-2">
		<img src="/iceberg-textlogo.png" alt="Iceberg Media" class="h-8 w-auto" />
	</a>

	<div class="hidden shrink flex-row items-center gap-8 lg:flex text-base">
		<HeaderDropDown
			label="Browse Themes"
			items={[
				{ href: '/themes/1/?price%5B%5D=free', label: 'Free Themes', icon: 'palette', prefetch: true },
				{ href: '/themes/1/?price%5B%5D=paid', label: 'Premium Themes', icon: 'palette', prefetch: true },
				{ href: '/themes/1/?categories%5B%5D=blog', label: 'Blog Themes', icon: 'palette', prefetch: true },
				{ href: '/themes/1/?categories%5B%5D=ecommerce', label: 'E-commerce', icon: 'palette', prefetch: true },
				{ href: '/themes/1/?categories%5B%5D=landing-page', label: 'Landing Pages', icon: 'palette', prefetch: true },
				{ href: '/themes/1/?categories%5B%5D=portfolio', label: 'Portfolio', icon: 'palette', prefetch: true },
				{ href: '/themes/1/?categories%5B%5D=docs', label: 'Documentation', icon: 'palette', prefetch: true },
				{ href: '/themes/', label: 'All Themes', icon: 'palette', prefetch: true },
			]}
		/>
		<HeaderDropDown
			label="Our Services"
			items={[
				{ href: '/services/theme-setup/', label: 'Theme Setup', icon: 'palette', prefetch: true },
				{ href: '/services/custom-design/', label: 'Custom Design', icon: 'palette', prefetch: true },
				{ href: '/services/seo-optimisation/', label: 'SEO Optimisation', icon: 'palette', prefetch: true },
				{ href: '/services/web-development/', label: 'Web Development', icon: 'palette', prefetch: true },
			]}
		/>
	</div>

	<div class="hidden gap-4 lg:flex">
		<a href="#contact-form" class="button button-primary button-sm">Get a Quote</a>
		<SocialLinks links={socialLinks} />
	</div>
</nav>

<script>
	import { getElement } from '~/helpers/dom.js';
	getElement('[data-home-link]', HTMLAnchorElement).addEventListener('contextmenu', (event) => {
		event.preventDefault();
		window.location.href = '/';
	});
</script>
