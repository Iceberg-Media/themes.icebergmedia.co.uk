---
import HeaderDropDown from './HeaderDropDown.astro';
---

<nav class="w-full flex items-center justify-between gap-4">
	<a href="https://icebergmedia.co.uk/" title="Iceberg Media - Manchester SEO Company" data-home-link class="flex items-center gap-4 shrink-0">
		<img src="/iceberg-textlogo.png" alt="Iceberg Media" class="h-12 w-auto" />
	</a>

	<div class="hidden shrink flex-row items-center gap-6 lg:flex text-base">
		<a href="/themes/" data-astro-prefetch class="link">Browse Themes</a>
		<HeaderDropDown
			label="Categories"
			items={[
				{ href: '/themes/free/', label: 'Free Themes', icon: 'palette', prefetch: true },
				{ href: '/themes/premium/', label: 'Premium Themes', icon: 'palette', prefetch: true },
				{ href: '/themes/blog/', label: 'Blog Themes', icon: 'palette', prefetch: true },
				{ href: '/themes/ecommerce/', label: 'E-commerce', icon: 'palette', prefetch: true },
				{ href: '/themes/landing-page/', label: 'Landing Pages', icon: 'palette', prefetch: true },
				{ href: '/themes/portfolio/', label: 'Portfolio', icon: 'palette', prefetch: true },
				{ href: '/themes/docs/', label: 'Documentation', icon: 'palette', prefetch: true },
			]}
		/>
		<a href="/services/" data-astro-prefetch class="link">Our Services</a>
		<HeaderDropDown
			label="What We Do"
			items={[
				{ href: '/services/theme-setup/', label: 'Theme Setup', icon: 'palette', prefetch: true },
				{ href: '/services/custom-design/', label: 'Custom Design', icon: 'palette', prefetch: true },
				{ href: '/services/seo-optimisation/', label: 'SEO Optimisation', icon: 'palette', prefetch: true },
				{ href: '/services/web-development/', label: 'Web Development', icon: 'palette', prefetch: true },
			]}
		/>
		<a href="/contact-us/" data-astro-prefetch class="link">Contact Us</a>
	</div>

	<div class="hidden gap-3 lg:flex shrink-0">
		<a href="#contact-form" class="button button-primary button-sm">Get a Quote</a>
	</div>
</nav>

<script>
	import { getElement } from '~/helpers/dom.js';
	getElement('[data-home-link]', HTMLAnchorElement).addEventListener('contextmenu', (event) => {
		event.preventDefault();
		window.location.href = '/';
	});
</script>
