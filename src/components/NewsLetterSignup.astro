---
interface Props {
	skipText?: boolean;
}

const { skipText = false } = Astro.props;
---

<div class={`${skipText ? 'mx-auto' : ''} flex flex-col md:max-lg:w-1/2 lg:max-w-sm`}>
	{
		!skipText && (
			<>
				<p class="font-semibold md:text-xl">Ready to launch?</p>
				<p class="mb-4 pt-2 text-astro-gray-200 lg:text-balance">
					Pick a theme, tell us your vision, and we'll build it for you. Professional setup, custom branding, fast turnaround.
				</p>
			</>
		)
	}
	<a href="#contact-form" class="button button-primary button-sm text-center">
		Get Started Today
	</a>
</div>
