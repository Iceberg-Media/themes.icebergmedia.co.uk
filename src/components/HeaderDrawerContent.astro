---
import { Icon } from 'astro-icon/components';
import siteInfo from '~/data/site-info.js';
import SocialLinks from './SocialLinks.astro';

const nav: Nav = [
	{
		label: 'Free Website Themes',
		items: [
			{ href: '/themes/free/', label: 'Free Themes', icon: 'palette', prefetch: true },
			{ href: '/themes/premium/', label: 'Premium Themes', icon: 'palette', prefetch: true },
			{ href: '/themes/blog/', label: 'Blog Themes', icon: 'palette', prefetch: true },
			{ href: '/themes/ecommerce/', label: 'E-commerce', icon: 'palette', prefetch: true },
			{ href: '/themes/landing-page/', label: 'Landing Pages', icon: 'palette', prefetch: true },
			{ href: '/themes/portfolio/', label: 'Portfolio', icon: 'palette', prefetch: true },
			{ href: '/themes/docs/', label: 'Documentation', icon: 'palette', prefetch: true },
		],
	},
	{
		label: 'Optimizations',
		items: [
			{ href: '/services/theme-setup/', label: 'Theme Setup', icon: 'palette', prefetch: true },
			{ href: '/services/custom-design/', label: 'Custom Design', icon: 'palette', prefetch: true },
			{ href: '/services/seo-optimisation/', label: 'SEO Optimisation', icon: 'palette', prefetch: true },
			{ href: '/services/web-development/', label: 'Web Development', icon: 'palette', prefetch: true },
		],
	},
	{ href: '/contact-us/', label: 'Contact', prefetch: true },
];

interface Link {
	href: string;
	label: string;
	prefetch?: true;
}
interface GroupLink extends Link {
	icon: string;
	badge?: string;
}
interface Group {
	label: string;
	items: GroupLink[];
}
type Nav = Array<Link | Group>;
---

<nav aria-label="Primary" class="text-xl flex flex-col divide-y divide-astro-gray-500 pb-12 text-left [&>*]:p-6">
	{nav.map((item) =>
		'href' in item ? (
			<a class="link" href={item.href} data-astro-prefetch={item.prefetch ? '' : undefined} set:text={item.label} />
		) : (
			<details class="group">
				<summary class="accordion link flex cursor-pointer list-none items-center justify-between">
					{item.label}
					<Icon name="chevron" aria-hidden="true" class="inline-block size-3 rotate-0 transition-transform group-open:-rotate-180 duration-300" />
				</summary>
				<div class="mt-4 flex flex-col gap-4 text-xl font-light">
					{item.items.map((link) => (
						<a href={link.href} data-astro-prefetch={link.prefetch ? '' : undefined} class="link flex items-center gap-4">
							<Icon name={link.icon} size="24" /> {link.label}
						</a>
					))}
				</div>
			</details>
		)
	)}
	<div class="flex flex-wrap justify-between gap-12 gap-y-6">
		<SocialLinks links={siteInfo.socialLinks} />
		<a href="#contact-form" class="button button-primary flex-grow sm:max-w-sm">Get a Quote</a>
	</div>
</nav>
