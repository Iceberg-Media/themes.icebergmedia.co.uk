---
import siteInfo from '~/data/site-info.js';
import SocialLinks from './SocialLinks.astro';

interface Props {
	bgClass?: string;
}

const { bgClass = 'bg-dark' } = Astro.props;

type Link = {
	href: string;
	label: string;
};

type LinkGroup = {
	title: string;
	links: Link[];
};

const groups: LinkGroup[] = [
	{
		title: 'Themes',
		links: [
			{ label: 'Free Themes', href: '/themes/1/?price%5B%5D=free' },
			{ label: 'Premium Themes', href: '/themes/1/?price%5B%5D=paid' },
			{ label: 'Blog Themes', href: '/themes/1/?categories%5B%5D=blog' },
			{ label: 'Portfolio Themes', href: '/themes/1/?categories%5B%5D=portfolio' },
			{ label: 'All Themes', href: '/themes/' },
		],
	},
	{
		title: 'Services',
		links: [
			{ label: 'Theme Setup', href: 'https://icebergmedia.co.uk' },
			{ label: 'Custom Design', href: 'https://icebergmedia.co.uk' },
			{ label: 'SEO Optimisation', href: 'https://icebergmedia.co.uk' },
			{ label: 'Web Development', href: 'https://icebergmedia.co.uk' },
		],
	},
	{
		title: 'Company',
		links: [
			{ label: 'About Us', href: 'https://icebergmedia.co.uk' },
			{ label: 'Contact', href: 'https://icebergmedia.co.uk' },
			{ label: 'Privacy Policy', href: '/privacy/' },
			{ label: 'Terms of Service', href: '/terms/' },
		],
	},
];

const socialLinks = siteInfo.socialLinks;
---

<footer class:list={['w-full border-t border-astro-dark-100/20', bgClass]}>
	<div class="w-full max-w-screen-2xl mx-auto px-4 sm:px-8">
		<nav
			aria-label="Secondary"
			class="flex flex-col lg:flex-row justify-between gap-20 py-8 md:py-12"
		>
			<div class="max-w-md">
				<div class="flex items-center gap-2 mb-4">
					<svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M16 2L28 26H4L16 2Z" fill="url(#iceberg-grad-footer)" stroke="url(#iceberg-grad-footer)" stroke-width="1"/>
						<path d="M16 8L22 22H10L16 8Z" fill="#0a0e1a" opacity="0.4"/>
						<defs>
							<linearGradient id="iceberg-grad-footer" x1="4" y1="2" x2="28" y2="26" gradientUnits="userSpaceOnUse">
								<stop stop-color="#3b82f6"/>
								<stop offset="1" stop-color="#06b6d4"/>
							</linearGradient>
						</defs>
					</svg>
					<span class="text-lg font-semibold text-white">Iceberg Themes</span>
				</div>
				<p class="text-astro-gray-300 text-sm mb-4">Browse the best Astro themes and let our team build your perfect website. Free and premium themes, professionally set up by Iceberg Media.</p>
				<a href="https://icebergmedia.co.uk" class="text-sm text-astro-gray-200 hover:text-white transition-colors">icebergmedia.co.uk</a>
			</div>

			<div class="gap-12 sm:gap-16 lg:gap-20 flex flex-wrap xl:grid xl:grid-cols-3">
				{
					groups.map(({ title, links }, index) => (
						<section class="group flex flex-col basis-32">
							<h2
								id={`footerHeading${index}`}
								class="mb-4 label-base leading-none text-white font-semibold"
							>
								{title}
							</h2>
							<ul aria-labelledby={`footerHeading${index}`} class="flex flex-col gap-2">
								{links.map(({ href, label }) => (
									<li>
										<a href={href} class="whitespace-nowrap link flex gap-2 items-center">
											{label}
										</a>
									</li>
								))}
							</ul>
						</section>
					))
				}
			</div>
		</nav>
		<hr class="border-astro-gray-500" />
		<nav
			aria-label="Legal"
			class="py-8 flex flex-col-reverse lg:flex-row items-center justify-between gap-4"
		>
			<div class="flex items-center gap-2 text-sm md:gap-4 md:text-base flex-wrap justify-center">
				<span class="text-astro-gray-300">
					&copy; {new Date().getFullYear()}&nbsp;Iceberg Media. All rights reserved.
				</span>
			</div>
			<SocialLinks links={socialLinks} />
		</nav>
	</div>
</footer>
